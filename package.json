{
    "name": "pikachu-pomodoro",
    "version": "1.0.0",
    "description": "A cute Pikachu-themed Pomodoro timer",
    "author": "Pyaari Ayesha",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "devDependencies": {
        "electron": "^40.6.1",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "electron-store": "^11.0.2"
    },
    "build": {
        "appId": "com.ayesha.pikachupomodoro",
        "productName": "Pikachu Pomodoro",
        "icon": "assets/pikachu-icon.ico",
        "files": [
            "**/*"
        ],
        "directories": {
            "buildResources": "assets"
        },
        "win": {
            "target": "nsis",
            "icon": "assets/pikachu-icon.ico",
            "forceCodeSigning": false
        }
    }
}