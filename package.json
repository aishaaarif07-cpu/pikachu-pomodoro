{
    "name": "pikachu-pomodoro",
    "version": "1.0.0",
    "description": "A cute Pikachu-themed Pomodoro timer",
    "author": "Pyaari Ayesha",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "devDependencies": {
        "electron": "^40.6.1",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "electron-store": "^11.0.2"
    },
    "build": {
        "appId": "com.ayesha.pikachupomodoro",
        "productName": "Pikachu Pomodoro",
        "icon": "assets/pikachu-icon.ico",
        "files": [
            "**/*"
        ],
        "directories": {
            "buildResources": "assets"
        },
        "win": {
            "target": "nsis",
            "icon": "assets/pikachu-icon.ico",
            "forceCodeSigning": false
        },
        "mac": {
            "target": "dmg",
            "icon": "assets/pikachu-icon.icns"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/aishaaarif07-cpu/pikachu-pomodoro.git"
    },
    "keywords": [],
    "license": "ISC",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/aishaaarif07-cpu/pikachu-pomodoro/issues"
    },
    "homepage": "https://github.com/aishaaarif07-cpu/pikachu-pomodoro#readme"
}